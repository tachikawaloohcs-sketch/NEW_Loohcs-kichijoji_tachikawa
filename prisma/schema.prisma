// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(cuid())
  name              String?
  email             String?  @unique
  password          String? // Optional for LINE-only users
  bio               String? // Instructor bio/subjects
  imageUrl          String? // Avatar image URL
  role              String // "ADMIN", "INSTRUCTOR", "STUDENT", "PARENT"
  isActive          Boolean  @default(true)
  isProfileComplete Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // LINE Integration
  lineUserId        String?  @unique
  campus            String? // "TACHIKAWA", "KICHIJOJI"


  // Student Profile
  schoolName         String? // 所属高校
  grade              String? // 学年 (高1, 高2, etc.)
  researchTheme      String? // 研究テーマ
  gpa                Float? // 評定平均
  qualifications     String? // 資格・実績
  canInternalUpgrade Boolean? // 内部進学が可能か

  // Dedicated Instructor Relation
  dedicatedInstructorId String?
  dedicatedInstructor   User?   @relation("DedicatedStudent", fields: [dedicatedInstructorId], references: [id])
  dedicatedStudents     User[]  @relation("DedicatedStudent")

  studentReports      Report[]  @relation("StudentReports")
  instructorReports   Report[]  @relation("InstructorReports")

  // Archiving & Admission
  archivedAt  DateTime?
  archiveYear Int?

  instructorAccesses ArchiveAccess[]   @relation("InstructorAccess")
  studentAccesses    ArchiveAccess[]   @relation("StudentAccess")
  admissionResults   AdmissionResult[]

  // Parent-Student Relation
  parentId String?
  parent   User?   @relation("ParentChildren", fields: [parentId], references: [id])
  children User[]  @relation("ParentChildren")

  hasChangedParentPassword Boolean @default(false)
  themes            ResearchTheme[] @relation("StudentThemes")
}

model ArchiveAccess {
  id           String   @id @default(cuid())
  instructorId String
  instructor   User     @relation("InstructorAccess", fields: [instructorId], references: [id])
  studentId    String
  student      User     @relation("StudentAccess", fields: [studentId], references: [id])
  createdAt    DateTime @default(now())

  @@unique([instructorId, studentId])
}

model AdmissionResult {
  id        String @id @default(cuid())
  studentId String
  student   User   @relation(fields: [studentId], references: [id])

  schoolName String
  department String?
  rank       Int // 1, 2, 3...

  status String @default("PENDING") // "PENDING", "PASSED_FIRST", "PASSED_FINAL", "REJECTED"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, rank])
}

model Report {
  id            String   @id @default(cuid())
  studentId     String
  student       User     @relation("StudentReports", fields: [studentId], references: [id])
  instructorId  String
  instructor    User     @relation("InstructorReports", fields: [instructorId], references: [id])
  content       String // Report content
  logUrl        String? // URL to class log
  homework      String? // Homework assigned
  feedback      String? // Student feedback
  date          DateTime @default(now()) // Shift date alternative
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model GlobalSettings {
  key         String   @id
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

// --- Locus Concept Models ---

model ResearchTheme {
  id          String   @id @default(cuid())
  studentId   String
  student     User     @relation("StudentThemes", fields: [studentId], references: [id])
  title       String
  status      String   @default("ACTIVE") // ACTIVE, FROZEN, ARCHIVED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  records     UpdateRecord[]
}

model UpdateRecord {
  id          String   @id @default(cuid())
  themeId     String
  theme       ResearchTheme @relation(fields: [themeId], references: [id])
  classDate   DateTime @default(now())

  // 1. 今の問い (Current Question)
  questionText      String
  questionChanged   Boolean  @default(false)

  // 2. 今の仮説 (Current Hypothesis)
  hypothesisText    String
  evidences         String // JSON string array
  unverifiedPremises String // JSON string array

  // 3. 外部接触 (External Contact)
  contactType       String   // "PREPARATION" or "REFLECTION"
  contactTarget     String?  // 誰に
  contactPurpose    String?  // 何を確かめるか
  contactExpectedRefutation String? // 想定反論
  contactReceivedFeedback String?   // 何を言われたか
  contactBrokenParts String?        // 何が崩れたか
  contactFixPlan    String?         // どう修正するか

  // 4. 再定義 (Redefinition)
  redefinitionText  String?  // 仮説／問いの変更点

  // 5. 振り返りと次なる一歩 (Reflection & Next Steps)
  studentReflection String?
  nextAction        String?

  // Comments from instructor
  instructorComment String?

  createdAt   DateTime @default(now())
}
