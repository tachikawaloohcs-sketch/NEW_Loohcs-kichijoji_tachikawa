// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(cuid())
  name              String?
  email             String?  @unique
  password          String? // Optional for LINE-only users
  bio               String? // Instructor bio/subjects
  imageUrl          String? // Avatar image URL
  role              String // "ADMIN", "INSTRUCTOR", "STUDENT"
  isActive          Boolean  @default(true)
  isProfileComplete Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // LINE Integration
  lineUserId        String?  @unique
  campus            String? // "TACHIKAWA", "KICHIJOJI"


  // Student Profile
  schoolName         String? // 所属高校
  grade              String? // 学年 (高1, 高2, etc.)
  researchTheme      String? // 研究テーマ
  gpa                Float? // 評定平均
  qualifications     String? // 資格・実績
  canInternalUpgrade Boolean? // 内部進学が可能か

  // Dedicated Instructor Relation
  dedicatedInstructorId String?
  dedicatedInstructor   User?   @relation("DedicatedStudent", fields: [dedicatedInstructorId], references: [id])
  dedicatedStudents     User[]  @relation("DedicatedStudent")

  // Relations
  instructorShifts  Shift[]           @relation("InstructorShifts")
  studentBookings   Booking[]         @relation("StudentBookings")
  shiftInstructions ShiftInstructor[] @relation("ShiftInstructors")

  sentRequests     ScheduleRequest[] @relation("StudentRequests")
  receivedRequests ScheduleRequest[] @relation("InstructorRequests")

  // Archiving & Admission
  archivedAt  DateTime?
  archiveYear Int?

  instructorAccesses ArchiveAccess[]   @relation("InstructorAccess")
  studentAccesses    ArchiveAccess[]   @relation("StudentAccess")
  admissionResults   AdmissionResult[]

  // Parent-Student Relation
  parentId String?
  parent   User?   @relation("ParentChildren", fields: [parentId], references: [id])
  children User[]  @relation("ParentChildren")
}

model ArchiveAccess {
  id           String   @id @default(cuid())
  instructorId String
  instructor   User     @relation("InstructorAccess", fields: [instructorId], references: [id])
  studentId    String
  student      User     @relation("StudentAccess", fields: [studentId], references: [id])
  createdAt    DateTime @default(now())

  @@unique([instructorId, studentId])
}

model AdmissionResult {
  id        String @id @default(cuid())
  studentId String
  student   User   @relation(fields: [studentId], references: [id])

  schoolName String
  department String?
  rank       Int // 1, 2, 3...

  status String @default("PENDING") // "PENDING", "PASSED_FIRST", "PASSED_FINAL", "REJECTED"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, rank])
}

model Shift {
  id           String   @id @default(cuid())
  instructorId String
  instructor   User     @relation("InstructorShifts", fields: [instructorId], references: [id])
  start        DateTime
  end          DateTime
  type         String // "INDIVIDUAL", "GROUP", "SPECIAL", "BEGINNER", "TRIAL"
  className    String? // For Group/Special
  isPublished  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  bookings         Booking[]
  shiftInstructors ShiftInstructor[] // Multiple instructors for group lessons
  maxCapacity      Int? // NULL = unlimited, number = max bookings

  location String @default("ONLINE") // "ONLINE", "KICHIJOJI", "TACHIKAWA"
}

model ShiftInstructor {
  id           String   @id @default(cuid())
  shiftId      String
  shift        Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  instructorId String
  instructor   User     @relation("ShiftInstructors", fields: [instructorId], references: [id])
  createdAt    DateTime @default(now())

  @@unique([shiftId, instructorId])
}

model Booking {
  id          String   @id @default(cuid())
  studentId   String
  student     User     @relation("StudentBookings", fields: [studentId], references: [id])
  shiftId     String
  shift       Shift    @relation(fields: [shiftId], references: [id])
  status      String // "CONFIRMED", "CANCELLED"
  meetingType String   @default("ONLINE") // "ONLINE", "IN_PERSON"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  report Report?
}

model Report {
  id            String   @id @default(cuid())
  bookingId     String   @unique
  booking       Booking  @relation(fields: [bookingId], references: [id])
  content       String // Report content
  logUrl        String? // URL to class log
  homework      String? // Homework assigned
  feedback      String? // Student feedback
  submittedLate Boolean  @default(false) // Whether the report was submitted late
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ScheduleRequest {
  id           String   @id @default(cuid())
  studentId    String
  student      User     @relation("StudentRequests", fields: [studentId], references: [id])
  instructorId String
  instructor   User     @relation("InstructorRequests", fields: [instructorId], references: [id])
  start        DateTime
  end          DateTime
  location     String   @default("ONLINE")
  type         String   @default("INDIVIDUAL") // "INDIVIDUAL", "GROUP"
  status       String   @default("PENDING") // "PENDING", "APPROVED", "REJECTED"
  message      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model GlobalSettings {
  key         String   @id
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}
